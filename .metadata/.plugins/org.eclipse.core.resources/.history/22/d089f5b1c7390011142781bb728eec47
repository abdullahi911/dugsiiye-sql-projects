-- Create enrollment table
CREATE TABLE enrollment (
    id INT PRIMARY KEY AUTO_INCREMENT,
    score_id INT,
    course_id INT,
    FOREIGN KEY (score_id) REFERENCES score(id),
    FOREIGN KEY (course_id) REFERENCES course(id)
);






