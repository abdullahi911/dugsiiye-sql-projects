create table courses (
id int primary key auto_increment,
title varchar(15)

);


-- Create enrollment table
CREATE TABLE enrollment (
    id INT PRIMARY KEY AUTO_INCREMENT,
    score_id INT,
    courses_id INT,
    FOREIGN KEY (score_id) REFERENCES score(id),
    FOREIGN KEY (courses_id) REFERENCES courses(id)
);
